# Roam — environment. All optional: with none set, the app runs on the
# in-memory MockRepository (fully functional demo, no external infra).

# --- Supabase (set both to switch from mock to Postgres) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Firebase Cloud Messaging (Phase 3 push; optional) ---
NEXT_PUBLIC_FCM_API_KEY=
NEXT_PUBLIC_FCM_PROJECT_ID=
NEXT_PUBLIC_FCM_SENDER_ID=
NEXT_PUBLIC_FCM_APP_ID=
NEXT_PUBLIC_FCM_VAPID_KEY=
FCM_SERVER_KEY=

# Google Gemini (AI 빠른 추천 등). https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 운영자 콘솔(/admin) 게이트. 설정 시 이 코드 입력해야 접근. 비우면 게이트 off.
ORGANIZER_CODE=

# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# env
.env
.env*.local

# keep example committed
!.env.example

# local agent tooling
.claude/

# Supabase SQL (migrations/seed/reset) — applied manually via SQL Editor, not versioned
supabase/

# 투명 로미 영상 원본(ProRes, 대용량) — 배포엔 변환된 .webm만
public/*.mov
